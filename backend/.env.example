DATABASE_URL=sqlite:///./price_comparison.db
# For PostgreSQL use:
# DATABASE_URL=postgresql://user:password@localhost/price_comparison

API_TITLE=Smart Price Comparison Platform
API_VERSION=1.0.0
DEBUG=True

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
